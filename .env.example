# =============================================================================
# NeighborhoodTools — Environment Configuration
# =============================================================================
# This file is the template. Copy it to `.env` and fill in the values below.
# `composer install` does the copy automatically when no `.env` exists yet.
#
# Each variable is marked [REQUIRED] or [OPTIONAL]:
#   - [REQUIRED] must be set or the app will not run correctly.
#   - [OPTIONAL] can stay blank unless the related feature is being used.
#
# This config is stack-agnostic — works with MAMP, XAMPP, Laragon, Docker,
# native Homebrew, or any LAMP/LEMP setup. Only the DB_* values change per
# stack. Defaults below assume a vanilla MySQL on localhost:3306.
# =============================================================================

# --- Application -------------------------------------------------------------
# [REQUIRED] APP_DEBUG=true loads unminified assets, shows full error traces,
# and bypasses Cloudflare Turnstile verification — appropriate for local
# development. Set to false (and APP_ENV=production) when deploying.
#
# APP_URL is the canonical site URL. Default below is fine for quick local
# checks, but several features (Turnstile widgets, Secure session cookies,
# the upgrade-insecure-requests CSP directive) work best over HTTPS. For
# the recommended local-HTTPS setup, see docs/local-setup.md.
APP_NAME=NeighborhoodTools
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost

# --- Database ----------------------------------------------------------------
# [REQUIRED] Adjust to match the local MySQL/MariaDB instance.
#
#   - DB_HOST: usually `localhost` or `127.0.0.1`. Docker setups often use
#     the container name or `host.docker.internal`.
#   - DB_PORT: 3306 by default. MAMP typically uses 8889. Docker varies.
#   - DB_USERNAME / DB_PASSWORD: must exist on the database server with
#     CREATE / SELECT / INSERT / UPDATE / DELETE privileges on DB_DATABASE.
#
# One-time database setup (replace `<user>` with the DB user that has
# CREATE privileges — often `root` locally, sometimes a dedicated user):
#
#     CREATE DATABASE neighborhoodtools;
#     mysql -u <user> -p neighborhoodtools < dumps/warren-jeremy-dump-phase6.sql
#
# The dump targets utf8mb4_0900_ai_ci (MySQL 8 default), so a bare
# CREATE DATABASE is sufficient — no explicit COLLATE clause needed.
# DB_COLLATION below pins the connection collation to match.
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=neighborhoodtools
DB_USERNAME=your_username
DB_PASSWORD=your_password
DB_COLLATION=utf8mb4_0900_ai_ci

# --- Sessions ----------------------------------------------------------------
# [REQUIRED] Idle timeout in seconds (1800 = 30 minutes). Sessions inactive
# longer than this are destroyed and require re-authentication.
SESSION_LIFETIME=1800

# --- Image processing (optional ImageMagick CLI binary) ----------------------
# [OPTIONAL] Path to the `magick` CLI binary. When set, image processing
# uses ImageMagick (better quality, AVIF variant generation). When blank,
# the app searches /bin, /usr/bin, /usr/local/bin, and $PATH; if no
# `magick` is found, it falls back to ext-gd (which does not support AVIF).
# Most local setups can leave this blank — set it only when ImageMagick
# is installed in a non-standard location.
MAGICK_BINARY=

# --- Google Geocoding (zip code → latitude/longitude) ------------------------
# [OPTIONAL] Used to geocode newly added zip codes. Existing seeded zip
# codes already carry coordinates, so this can stay blank for local
# development unless new zip codes are being added.
GOOGLE_GEOCODING_API_KEY=

# --- Cloudflare Turnstile (bot protection on auth forms) ---------------------
# [OPTIONAL in development] When APP_DEBUG=true the app skips Turnstile
# verification, so login / register / forgot-password work with all three
# values blank. Production requires all three.
#
# TURNSTILE_ALLOWED_HOSTNAMES is a comma-separated list of hostnames the
# verification accepts. The local hostname must be added here when running
# APP_DEBUG=false locally (e.g., to test the full auth flow before deploy).
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_ALLOWED_HOSTNAMES=localhost

# --- Stripe (security deposits) ----------------------------------------------
# [OPTIONAL] Required only when exercising the security-deposit payment
# flow on borrow handovers. Browsing, borrowing, ratings, admin, events,
# disputes, incidents, and waivers all work without Stripe configured.
#
# STRIPE_WEBHOOK_SECRET is the endpoint signing secret (starts with
# `whsec_`), not the API key. Get it from Stripe Dashboard → Developers
# → Webhooks → endpoint → "Signing secret".
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
