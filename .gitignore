*.bak
*.tmp
*.swp

# User uploads (keep directory structure via .gitkeep)
public/uploads/incidents/*
public/uploads/profiles/*
public/uploads/tools/*
public/uploads/vectors/*
!public/uploads/**/.gitkeep

# Rate limit data files
storage/rate-limits/*.json
!storage/rate-limits/.gitkeep
!storage/rate-limits/.htaccess

