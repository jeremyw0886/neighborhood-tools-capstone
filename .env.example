# =============================================================================
# NeighborhoodTools — Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in the values below.
# Variables marked [REQUIRED] must be set. [OPTIONAL] vars can stay blank
# unless you want to exercise that specific feature.
# =============================================================================

# --- Application -------------------------------------------------------------
# [REQUIRED] Leave APP_ENV=development and APP_DEBUG=true for local testing.
# Development mode loads unminified assets and bypasses Turnstile bot checks.
APP_NAME=NeighborhoodTools
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost

# --- Database ----------------------------------------------------------------
# [REQUIRED] Before importing the SQL dump:
#
#     CREATE DATABASE neighborhoodtools;
#     mysql -u root -p neighborhoodtools < dumps/warren-jeremy-dump-phase6.sql
#
# The dump targets utf8mb4_0900_ai_ci (MySQL 8 default). The CREATE
# DATABASE statement above is intentionally bare — MySQL 8's default
# collation matches the dump, so no explicit COLLATE clause is needed.
# DB_COLLATION below pins the connection collation to match.
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=neighborhoodtools
DB_USERNAME=your_username
DB_PASSWORD=your_password
DB_COLLATION=utf8mb4_0900_ai_ci

# --- Sessions ----------------------------------------------------------------
# [REQUIRED] Idle timeout in seconds (1800 = 30 minutes).
SESSION_LIFETIME=1800

# --- Google Geocoding (zip code → lat/lng) -----------------------------------
# [OPTIONAL] Used by zip_code.php and neighborhood.php to geocode new zip
# codes. Leave blank for testing — existing seeded zip codes already have
# coordinates and the app will not crash without this.
GOOGLE_GEOCODING_API_KEY=

# --- Cloudflare Turnstile (bot protection on auth forms) ---------------------
# [OPTIONAL in development] When APP_DEBUG=true the app skips Turnstile
# verification, so login/register/forgot-password work with these blank.
# Leave them empty for testing.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_ALLOWED_HOSTNAMES=localhost

# --- Stripe (security deposits) ----------------------------------------------
# [OPTIONAL] Required only if you want to test the security-deposit payment
# flow on borrow handovers. The rest of the app (browsing, borrowing,
# ratings, admin, events, disputes) works without these. Leave blank to
# skip payment testing.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
