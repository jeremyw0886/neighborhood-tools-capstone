.DS_Store
Thumbs.db

# VS Code
.vscode/*
.vscode/settings.json
.vscode/extensions.json

# PHP dependencies (root Composer vendor only)
/vendor/

# Environment and credentials
.env
.env.local
.env.*.local
config.local.php
credentials.json
*.pem

