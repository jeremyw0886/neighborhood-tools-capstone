# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/

# Claude
.claude/
CLAUDE.md

# PHP dependencies (installed via `composer install`)
/vendor/

# Environment and credentials
.env
.env.local
.env.*.local
config.local.php
credentials.json
*.pem

# SQL — block all except the required course deliverable
*.sql
*.sql.gz
!dumps/warren-jeremy-dump-phase6.sql

# Logs
logs/*.log
*.log
error_log
php_errorlog
public/php_errorlog

# Backups and temp files
*.bak
*.tmp
*.swp

# Uploads — keep directory structure and committed seed images,
# block runtime-uploaded files only via the .htaccess/.gitkeep allowlist below
!public/uploads/**/.gitkeep
!public/uploads/**/.htaccess

# Runtime storage (keep directory structure via .gitkeep)
storage/rate-limits/*.json
!storage/rate-limits/.gitkeep
!storage/rate-limits/.htaccess
storage/cache/*.json
!storage/cache/.gitkeep
!storage/cache/.htaccess
storage/sessions/*
!storage/sessions/.gitkeep

# Local-only working folders (not part of the deliverable)
local_testing/
seed_images/
usability_testing/
_archive/

# Server-specific cron reference (paths differ per host)
cron/siteground-cron-commands.txt

# Usability test artifacts (kept locally, not deployed)
public/usability-test-*.html
public/assets/js/usability-test.js
